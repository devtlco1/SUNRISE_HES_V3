# Set to "true" to skip /api/meters and render the Meters page from bundled JSON (offline UI work).
# NEXT_PUBLIC_METERS_USE_MOCK=true

# Set to "true" to skip /api/connectivity and render the Connectivity page from bundled JSON.
# NEXT_PUBLIC_CONNECTIVITY_USE_MOCK=true

# Alarms use persisted operational-alarms.json + GET /api/alarms (NEXT_PUBLIC_ALARMS_USE_MOCK is unused).

# Set to "true" to skip /api/commands and render the Commands jobs table from bundled JSON.
# NEXT_PUBLIC_COMMANDS_USE_MOCK=true

# Inbound meter TCP ingress (optional). See docs/runtime-ingress.md
# RUNTIME_TCP_METER_INGRESS_ENABLED=true
# RUNTIME_TCP_METER_INGRESS_HOST=0.0.0.0
# RUNTIME_TCP_METER_INGRESS_PORT=
# RUNTIME_TCP_METER_INGRESS_SOCKET_TIMEOUT_SECONDS=120
# INTERNAL_API_TOKEN=

# Inbound DLMS session / vendor profile (server only; never commit passwords)
# RUNTIME_INGRESS_DLMS_SESSION_ENABLED=true
# RUNTIME_INGRESS_DLMS_AUTH=LOW
# RUNTIME_INGRESS_DLMS_PASSWORD=
# RUNTIME_INGRESS_DLMS_CLIENT_LOGICAL=1
# RUNTIME_INGRESS_DLMS_METER_ADDRESS_HEX=
# RUNTIME_INGRESS_VENDOR_BROADCAST_SNRM_HEX=
# RUNTIME_INGRESS_DLMS_READ_TIMEOUT_SECONDS=2.5
# RUNTIME_INGRESS_IDENTITY_OBIS=0.0.96.1.1.255
# RUNTIME_INGRESS_LAST_SESSION_TRACE_PATH=/var/log/sunrise-ingress-last.json

# --- Auth (signed session cookie; server-only) ---
# HMAC secret for session tokens; min 32 characters in production.
# SUNRISE_AUTH_SECRET=

# Session cookie `Secure` flag. When unset, derived from X-Forwarded-Proto / request URL
# (http → false, https → true). Plain HTTP on a raw IP / port (e.g. http://x.x.x.x:3000)
# needs false or the browser will not store the cookie — set explicitly for those hosts:
# SUNRISE_AUTH_COOKIE_SECURE=false
# Behind TLS termination with correct X-Forwarded-Proto: https, leave unset or use true.

# OBIS catalog: restore full vendor set from PRM SQL with `npm run obis:catalog:generate`;
# prune to meter-supported codes from a readings CSV with `npm run obis:prune-from-readings-csv`
# (writes `data/backups/obis-catalog-pre-readings-prune-*.json` locally — not committed).

# Python protocol sidecar (server-only; Next proxies via /api/internal/python-runtime/read-identity)
# RUNTIME_PYTHON_SIDECAR_URL=http://127.0.0.1:8766
# RUNTIME_PYTHON_SIDECAR_TOKEN=
# Align with Python when overriding basic-registers OBIS (internal routes catalog-check against latest discovery snapshot)
# SUNRISE_RUNTIME_BASIC_REGISTERS_OBIS=0.0.1.0.0.255,1.0.1.8.0.255,1.0.32.7.0.255
