SUNRISE_RUNTIME_HOST=0.0.0.0
SUNRISE_RUNTIME_PORT=8766
SUNRISE_RUNTIME_LOG_LEVEL=INFO
SUNRISE_RUNTIME_ADAPTER=stub
# SUNRISE_RUNTIME_SERVICE_TOKEN=long-random-secret

# Real serial path (adapter=mvp_ami): clone https://github.com/devtlco1/MVP-AMI
# SUNRISE_RUNTIME_ADAPTER=mvp_ami
# SUNRISE_RUNTIME_MVP_AMI_ROOT=/absolute/path/to/MVP-AMI
# SUNRISE_RUNTIME_MVP_AMI_CONFIG_PATH=/absolute/path/to/MVP-AMI/config.json
# SUNRISE_RUNTIME_IDENTITY_OBIS=0.0.96.1.1.255
# Comma-separated OBIS for read-basic-registers (defaults in config if unset)
# SUNRISE_RUNTIME_BASIC_REGISTERS_OBIS=0.0.1.0.0.255,1.0.1.8.0.255,1.0.32.7.0.255
