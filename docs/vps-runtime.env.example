# Copy to the VPS as a gitignored env file (e.g. .env.production.local).
# Do NOT commit this file with real host/port values.
# Replace placeholders on the server only.

RUNTIME_ADAPTER=real
RUNTIME_PROBE_HOST=REPLACE_WITH_FIELD_GATEWAY_HOST
RUNTIME_PROBE_PORT=REPLACE_WITH_FIELD_GATEWAY_PORT
RUNTIME_PROBE_TIMEOUT_MS=5000

# Inbound meter → server (listener). Set on VPS only; do not commit real values.
# RUNTIME_TCP_METER_INGRESS_ENABLED=true
# RUNTIME_TCP_METER_INGRESS_HOST=0.0.0.0
# RUNTIME_TCP_METER_INGRESS_PORT=REPLACE_WITH_INGRESS_PORT
# RUNTIME_TCP_METER_INGRESS_SOCKET_TIMEOUT_SECONDS=120
# INTERNAL_API_TOKEN=REPLACE_WITH_LONG_RANDOM_TOKEN
